<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if(entry.isIntersecting){
      entry.target.classList.add('visible');
    }
  });
});

document.querySelectorAll('.fade').forEach(el => observer.observe(el));
</script>

<style>
.navbar {
  position: fixed;
  top: 0;
  width: 100%;
  display: flex;
  justify-content: space-between; /* separa izquierda y derecha */
  align-items: center; /* centra verticalmente */
  padding: 15px 40px;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(10px);
  z-index: 100;
   box-sizing: border-box;
}
.nav-links {
  display: flex;
  gap: 20px;
}
{
  top:0;
  width:100%;
  display:flex;
  justify-content:space-between;
  padding:15px 40px;
  background:rgba(0,0,0,0.5);
  backdrop-filter:blur(10px);
  z-index:100;
}

.navbar a {
  margin-left:15px;
  color:white;
  text-decoration:none;
  padding:8px 14px;
  border-radius:8px;
  transition: all 0.3s ease;
}

.navbar a:hover {
  background: rgba(56,189,248,0.2);
  color:#38bdf8;
}

/* BOTONES REDES */
.social-btn {
  display:inline-block;
  padding:10px 18px;
  margin-top:10px;
  margin-right:10px;
  border-radius:8px;
  font-weight:bold;
  text-decoration:none;
  transition: all 0.3s ease;
}

.github-btn {
  background:#111827;
  border:1px solid #38bdf8;
}

.github-btn:hover {
  background:#38bdf8;
  color:black;
}

.linkedin-btn {
  background:#0a66c2;
}

.linkedin-btn:hover {
  background:#38bdf8;
  color:black;
}

.hero { padding:120px 60px; display:flex; justify-content:space-between; }

.gradient-text {
  background:linear-gradient(90deg,#38bdf8,#818cf8);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.hero-img img { width:200px; border-radius:50%; box-shadow:0 0 30px #38bdf8; }
.btn { padding:10px 20px; border-radius:8px; }

.cv-btn {
  background: linear-gradient(90deg,#38bdf8,#818cf8);
  color:black;
  font-weight:bold;
  box-shadow:0 0 15px rgba(56,189,248,0.6);
}

.cv-btn:hover {
  transform:scale(1.05);
}

.big { padding:14px 26px; font-size:16px; }

.section { padding:80px 60px; }

.grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:25px; }

.glass { background:rgba(255,255,255,0.05); backdrop-filter:blur(10px); border-radius:15px; padding:20px; }

.project img {
  width:100%;
  height:200px;
  object-fit:cover;
  border-radius:10px;
}

.project:hover { transform:translateY(-10px); transition:0.3s; }

.tags span { background:#38bdf8; color:black; padding:4px 8px; margin:4px; border-radius:6px; }

.skills-container { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:25px; }

.fade { opacity:0; transform:translateY(20px); transition:0.6s; }
.visible { opacity:1; transform:translateY(0); }
</style>